# Copy this file to .env and fill in your values
# Gmail: enable 2-Step Verification → Google Account → Security → App Passwords → generate one
# Generate SECRET_KEY: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-this-with-a-long-random-string

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=adtcfirozabadup@gmail.com
SMTP_PASS=xxxx_xxxx_xxxx_xxxx
FROM_EMAIL=adtcfirozabadup@gmail.com

# Comma-separated list of allowed frontend origins (set to your Netlify URL in production)
ALLOWED_ORIGINS=http://localhost:5500,https://your-site.netlify.app

DB_PATH=enrollments.db

FLASK_DEBUG=false
PORT=5000
